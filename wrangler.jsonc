        {
            "binding": "DB",
            "database_name": "navigation-db",
            "database_id": "013e3c8d-cd05-4220-b0f8-91cf4d2e4090"
        }
    ],
    "vars": {
        "AUTH_ENABLED": "true",
        "AUTH_USERNAME": "noccp",
